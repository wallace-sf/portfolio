{
  "name": "@repo/utils",
  "version": "0.0.0",
  "private": true,
  "os": [
    "linux"
  ],
  "main": "src/index.ts",
  "exports": {
    ".": { "types": "./dist/types/index.d.ts", "default": "./src/index.ts" },
    "./validator": { "types": "./dist/types/validator/index.d.ts", "default": "./src/validator/index.ts" },
    "./env": { "types": "./dist/types/env/index.d.ts", "default": "./src/env/index.ts" }
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watchAll --collectCoverage",
    "lint": "eslint --fix --ext .ts ./src",
    "lint:check": "eslint --ext .ts ./src",
    "format": "prettier --write ./src/**/*.ts",
    "format:check": "prettier --check ./src/**/*.ts",
    "build:types": "tsc --build tsconfig.build.json",
    "types": "tsc --build tsconfig.build.json"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/react": "^16.0.1",
    "@types/lodash": "*",
    "@types/luxon": "^3.4.2",
    "@types/mustache": "^4.2.5",
    "@types/react": "^18",
    "@types/validator": "^13.12.1"
  },
  "dependencies": {
    "imask": "^7.6.1",
    "luxon": "^3.5.0",
    "mustache": "^4.2.0",
    "react": "^18",
    "validator": "^13.12.0",
    "zod": "^4.3.6"
  }
}
