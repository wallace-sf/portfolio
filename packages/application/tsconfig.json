{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "~/*": ["*"]
    }
  },
  "references": [
    { "path": "../utils/tsconfig.build.json" },
    { "path": "../core/tsconfig.build.json" }
  ],
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist", "build"]
}
