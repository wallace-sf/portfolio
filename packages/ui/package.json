{
  "name": "@repo/ui",
  "version": "0.0.0",
  "sideEffects": [
    "*.css"
  ],
  "private": true,
  "exports": {
    "./globals.css": "./globals.css",
    "./Control": {
      "types": "./dist/types/Control/index.d.ts",
      "import": "./dist/Control/index.mjs",
      "require": "./dist/Control/index.js"
    },
    "./Control/Button/Link": {
      "types": "./dist/Control/Button/Link/index.d.ts",
      "import": "./dist/Control/Button/Link/index.mjs",
      "require": "./dist/Control/Button/Link/index.js"
    },
    "./Imagery": {
      "types": "./dist/types/Imagery/index.d.ts",
      "import": "./dist/Imagery/index.mjs",
      "require": "./dist/Imagery/index.js"
    },
    "./View": {
      "types": "./dist/types/View/index.d.ts",
      "import": "./dist/View/index.mjs",
      "require": "./dist/View/index.js"
    }
  },
  "os": [
    "linux"
  ],
  "files": [
    "dist/",
    "globals.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint --fix --ext .ts,.tsx src",
    "lint:check": "eslint --ext .ts,.tsx src",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "build:types": "tsc --build tsconfig.build.json",
    "types": "tsc --build tsconfig.build.json"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "dependencies": {
    "@iconify/react": "^5.0.2",
    "@repo/utils": "workspace:*",
    "classnames": "^2.5.1",
    "github-markdown-css": "^5.9.0",
    "hast-util-sanitize": "^5.0.2",
    "mermaid": "^11.15.0",
    "react-markdown": "^9.0.1",
    "react-tooltip": "^5.28.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mark-highlight": "^0.1.1",
    "tiny-invariant": "^1.3.3",
    "unified": "^11.0.5",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.3.5"
  }
}
