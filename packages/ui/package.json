{
  "name": "@repo/ui",
  "version": "0.0.0",
  "sideEffects": false,
  "private": true,
  "exports": {
    "./Control": {
      "types": "./dist/types/Control/index.d.ts",
      "import": "./dist/Control/index.js",
      "require": "./dist/Control/index.js"
    },
    "./Imagery": {
      "types": "./dist/types/Imagery/index.d.ts",
      "import": "./dist/Imagery/index.js",
      "require": "./dist/Imagery/index.js"
    },
    "./View": {
      "types": "./dist/types/View/index.d.ts",
      "import": "./dist/View/index.js",
      "require": "./dist/View/index.js"
    }
  },
  "os": [
    "linux"
  ],
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint --fix --ext .ts,.tsx src",
    "lint:check": "eslint --ext .ts,.tsx src",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "build:types": "tsc --build tsconfig.build.json",
    "types": "tsc --build tsconfig.build.json"
  },
  "dependencies": {
    "@iconify/react": "^5.0.2",
    "@repo/utils": "workspace:*",
    "classnames": "^2.5.1",
    "formik": "^2.4.6",
    "react": "^18",
    "react-markdown": "^9.0.1",
    "react-tooltip": "^5.28.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "tiny-invariant": "^1.3.3",
    "usehooks-ts": "^3.1.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.3.5"
  }
}
