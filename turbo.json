{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "RESEND_API_KEY",
    "CONTACT_EMAIL_TO",
    "CONTACT_EMAIL_FROM",
    "ADMIN_EMAIL",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SITE_API_URL",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "site#build": {
      "dependsOn": ["^build"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "admin#build": {
      "dependsOn": ["^build"],
      "env": ["NEXT_PUBLIC_*", "SITE_API_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:check": {
      "dependsOn": ["^lint:check"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "format:check": {
      "dependsOn": ["^format:check"]
    },
    "types": {
      "dependsOn": ["^types"],
      "outputs": ["dist/types/**"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "ui": "tui"
}
