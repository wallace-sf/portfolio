# Admin app environment variables
#
# Do NOT add real credentials here — this file is committed to git.
#
# Copy to apps/admin/.env.local and fill in your values for local development.
# In production, set these variables through your hosting platform (e.g. Vercel).

# ── Site API (apps/site) ──────────────────────────────────────────────────────
# Base URL of the apps/site instance that serves the REST API (/api/v1/...).
# Server-side: used by admin layout to verify authentication via /api/v1/me.
# Defaults to http://localhost:3000 when omitted.
SITE_API_URL="http://localhost:3000"

# Client-side counterpart of SITE_API_URL (exposed to the browser).
# Used by LoginForm and AdminSidebar to call auth endpoints on apps/site.
# Defaults to empty string (relative URLs) when omitted — only works when
# both apps are served from the same origin (e.g. behind a reverse proxy).
NEXT_PUBLIC_SITE_API_URL="http://localhost:3000"
