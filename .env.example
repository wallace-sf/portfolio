# Environment variables reference
#
# Do NOT add real credentials here — this file is committed to git.
#
# Local development setup (two gitignored files):
#   cp .env.example .env.local                                    ← Next.js dev server
#   cp .env.example packages/infra/.env.test.local               ← Vitest integration tests
#
# See docs/01-GETTING-STARTED.md → "Environment Variables" for full setup instructions.

# ── Database (Supabase Postgres) ───────────────────────────────────────────────
#
# Local (pnpm db:start):
#   DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
#   DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
#
# Cloud (supabase.com → Project Settings → Database → Connection string):
#   Use "Transaction" mode (port 6543) for DATABASE_URL.
#   Use "Session" mode (port 5432) for DIRECT_URL.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Resend (email service) ─────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Recipient of contact form submissions.
CONTACT_EMAIL_TO="your@email.com"
# Sender address (must be a verified domain in Resend).
CONTACT_EMAIL_FROM="onboarding@resend.dev"

# ── Identity ────────────────────────────────────────────────────────────────────
# Email of the initial admin user created by the seed script.
# Defaults to "admin@portfolio.dev" if not set.
ADMIN_EMAIL="admin@portfolio.dev"

# ── Supabase Auth (server-side — used by SupabaseAuthenticationGateway) ────────
#
# Local (pnpm db:start) — fixed for all local instances:
#   SUPABASE_URL="http://127.0.0.1:54321"
#   SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqHeDTh4yHoSp_QQdvkpR9aA7Pjvqr5tg"
#
# Cloud (supabase.com → Project Settings → API):
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
