meta {
  name: Send Contact Message
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/contact
  body: json
  auth: none
}

headers {
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "name": "Wallace",
    "email": "wallace@example.com",
    "message": "Hello, this is a test message from Bruno."
  }
}
